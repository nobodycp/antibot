# Copy to ".env" in the project root (same directory as manage.py).
# The real ".env" file is gitignored.

# Django secret key (use a long random string in production).
# If unset, the legacy development default in settings is used so startup still works.
# SECRET_KEY=
# Alias (either name is accepted):
# DJANGO_SECRET_KEY=

# Telegram bot credentials are stored in the database (Telegram backup settings in the dashboard).
# You can keep managing them there; these env vars are optional overrides for tooling/scripts only.
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# Optional geolocation / IP enrichment API keys (not required for current public endpoints).
# IPAPI_API_KEY=
# IPINFO_API_TOKEN=
