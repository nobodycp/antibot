# Copy to ".env" in the project root (same directory as manage.py).
# The real ".env" file is gitignored.

# Environment: unset or "development" → dev settings (DEBUG on). "production" or "prod" → prod settings.
# Loaded before settings are chosen (see analytics_project/settings/__init__.py).
# DJANGO_ENV=production

# Production behind Nginx/HTTPS: set ALLOWED_HOSTS to your public hostname(s) and IP(s), comma-separated.
# ALLOWED_HOSTS=example.com,www.example.com,203.0.113.10
#
# When TLS terminates at a trusted reverse proxy only (Gunicorn not reachable directly by clients):
# USE_X_FORWARDED_PROTO=1  → SECURE_PROXY_SSL_HEADER for HTTPS detection (see prod.py).
# CSRF_TRUSTED_ORIGINS=https://example.com,https://www.example.com  (comma-separated origins, Django 4+ HTTPS).
# DJANGO_SECURE_COOKIES=1  → SESSION_COOKIE_SECURE and CSRF_COOKIE_SECURE (HTTPS-only sites).

# Django secret key — required in production (DJANGO_ENV=production).
# Development: optional; if unset, dev settings use a local placeholder (not for production).
# SECRET_KEY=
# Alias (either name is accepted):
# DJANGO_SECRET_KEY=

# Django cache (django-redis): rate limits, IP enrichment cache. Default if unset: redis://127.0.0.1:6379/1
# install.sh installs redis-server and sets REDIS_URL to local Redis; override if you use a remote Redis.
# REDIS_URL=

# --- install.sh only (not read by Django; set when invoking the installer, not in project .env) ---
# Optional superuser password; if unset, install.sh generates one and writes /root/antibot_superuser_credentials.txt
# ANTIBOT_SUPERUSER_PASSWORD=
# ANTIBOT_SUPERUSER_USERNAME=admin
# ANTIBOT_SUPERUSER_EMAIL=admin@localhost
# ALLOWED_HOSTS in /opt/antibot/.env is auto-filled (loopback, route IP, hostname -I, optional public IP via curl).
# Full override for next install run: ANTIBOT_ALLOWED_HOSTS=example.com,203.0.113.1
# Append domains/extra hosts: ANTIBOT_EXTRA_ALLOWED_HOSTS=example.com,www.example.com (use sudo -E if needed)
# ANTIBOT_ALLOWED_HOSTS=
# ANTIBOT_EXTRA_ALLOWED_HOSTS=

# Database: omit DB_NAME (or leave it empty) to use SQLite (db.sqlite3 in project root) — typical for local dev.
# Production installs via install.sh: PostgreSQL is provisioned automatically and this file is written with DB_* set.
# Manual PostgreSQL: set DB_NAME, DB_USER, DB_PASSWORD, DB_HOST (and optional DB_PORT); ensure PostgreSQL is running.
# Requires: pip install -r requirements.txt (includes psycopg2-binary).
# DB_NAME=antibot
# DB_USER=antibot
# DB_PASSWORD=
# DB_HOST=127.0.0.1
# DB_PORT=5432
# Optional pool keep-alive seconds (0 = Django opens/closes per request)
# DB_CONN_MAX_AGE=0

# Telegram bot credentials are stored in the database (Telegram backup settings in the dashboard).
# You can keep managing them there; these env vars are optional overrides for tooling/scripts only.
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# Optional geolocation / IP enrichment API keys (not required for current public endpoints).
# IPAPI_API_KEY=
# IPINFO_API_TOKEN=
